# Auth
JWT_SECRET=replace-with-a-long-random-string
ADMIN_EMAIL=admin@video2pdf.ai
ADMIN_PASSWORD_HASH=$2a$10$examplebcrypthashadmin
MARKETING_EMAIL=marketing@video2pdf.ai
MARKETING_PASSWORD_HASH=$2a$10$examplebcrypthashmarketing

# App Store Connect (Sales & Trends)
# APPSTORE_PRIVATE_KEY is the full contents of the .p8 file. Newlines may be escaped as \n.
APPSTORE_KEY_ID=
APPSTORE_ISSUER_ID=
APPSTORE_PRIVATE_KEY=
APPSTORE_VENDOR_NUMBER=

# Google Play (Play Console statistics exports in Cloud Storage)
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON is the full service-account JSON, on one line.
# GOOGLE_PLAY_STATS_BUCKET is the developer bucket from Play Console >
# Download reports > Copy Cloud Storage URI (pubsite_prod_rev_...). The
# service account needs "View app information and download bulk reports".
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_PACKAGE_NAME=com.vid2pdf.app
GOOGLE_PLAY_STATS_BUCKET=pubsite_prod_rev_XXXXXXXXXXXXXXXXXXXX
GOOGLE_PLAY_SUBSCRIPTION_PRODUCT_ID=video2pdf_pro_annual

# PostHog (Trends insight API)
# POSTHOG_API_KEY is a personal API key (phx_...), not the app's project key (phc_...).
# This project lives in the EU region.
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.posthog.com
POSTHOG_PROJECT_ID=226315

# AppsFlyer (aggregate performance report, Pull API)
# One app per platform; installs and cost are summed across both.
APPSFLYER_API_TOKEN=
APPSFLYER_IOS_APP_ID=id6761927204
APPSFLYER_ANDROID_APP_ID=com.vid2pdf.app

# Meta (Marketing/Graph API insights)
# META_AD_ACCOUNT_ID with or without the act_ prefix.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# TikTok (Reporting API)
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# ==========================================================================
# Web2App funnel (/go): Stripe web checkout + Meta Pixel + Postgres bridge
# ==========================================================================

# --- Site basics ---
# Used to build Stripe success/cancel URLs. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://video2pdf.ai
# Optional. Redeem-token lifetime in ms. Defaults to 7 days if unset.
REDEEM_TOKEN_TTL_MS=604800000

# --- Stripe ---
# STRIPE_SECRET_KEY: Stripe > Developers > API keys (sk_live_... or sk_test_...).
# STRIPE_WEBHOOK_SECRET (whsec_...): shown when you create the webhook endpoint
#   pointing at https://<site>/api/stripe/webhook. Set that endpoint's API
#   version to 2026-06-24.dahlia so payload shapes match the code.
# STRIPE_PRICE_WEEKLY / _ANNUAL: the two recurring Price ids you create.
#   Weekly $4.99/wk (no trial). Annual $29.99/yr (the 3-day trial is applied
#   by our checkout code, not configured on the Price itself).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_WEEKLY=
STRIPE_PRICE_ANNUAL=

# --- Meta Pixel + Conversions API ---
# Create a Pixel in Meta Events Manager and generate a CAPI access token.
# NEXT_PUBLIC_META_PIXEL_ID and META_PIXEL_ID are the SAME id (public browser
# pixel vs server-side CAPI). META_CAPI_ACCESS_TOKEN is the CAPI token.
NEXT_PUBLIC_META_PIXEL_ID=
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=

# --- Postgres (Supabase via Vercel > Storage) ---
# Create a NEW Supabase database from the Vercel Storage tab (not any DB that
# belongs to another project). It auto-injects POSTGRES_* into this project (do
# NOT hand-copy them here). Then run lib/db/schema.sql once: `npm run db:setup`.
# The SERVER (api.video2pdf.ai) needs the same connection string as DATABASE_URL
# in ITS own env (see video2pdf-app/server). Use Supabase's SESSION pooler
# connection string (port 5432) for the server, not the transaction pooler.
# POSTGRES_URL is listed here only so local `npm run db:setup` can find it.
POSTGRES_URL=
